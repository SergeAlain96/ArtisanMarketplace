{
  "info": {
    "name": "Artisan Marketplace API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection de test pour la phase 2 backend"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "userToken", "value": "" },
    { "key": "artisanToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "artisanId", "value": "" },
    { "key": "productId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register (user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice User\",\n  \"email\": \"alice.user@test.com\",\n  \"password\": \"Password123\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/register (artisan)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Artisan\",\n  \"email\": \"bob.artisan@test.com\",\n  \"password\": \"Password123\",\n  \"role\": \"artisan\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice.user@test.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Artisans",
      "item": [
        {
          "name": "POST /artisan/profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{artisanToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Handmade ceramics artisan\",\n  \"location\": \"Paris\",\n  \"avatarUrl\": \"\"\n}"
            },
            "url": "{{baseUrl}}/artisan/profile"
          }
        },
        {
          "name": "GET /artisans",
          "request": { "method": "GET", "url": "{{baseUrl}}/artisans" }
        },
        {
          "name": "GET /artisan/:id",
          "request": { "method": "GET", "url": "{{baseUrl}}/artisan/{{artisanId}}" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "POST /products",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{artisanToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ceramic Vase\",\n  \"description\": \"Handmade white ceramic vase\",\n  \"price\": 45,\n  \"images\": []\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "GET /products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?page=1&limit=10" }
        },
        {
          "name": "PUT /products/:id",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{artisanToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 49\n}" },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "DELETE /products/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{artisanToken}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Ratings",
      "item": [
        {
          "name": "POST /ratings",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"artisanId\": \"{{artisanId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent work\"\n}"
            },
            "url": "{{baseUrl}}/ratings"
          }
        },
        {
          "name": "GET /artisan/:id/ratings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/artisan/{{artisanId}}/ratings"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /admin/artisans",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/artisans"
          }
        },
        {
          "name": "DELETE /admin/product/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/product/{{productId}}"
          }
        }
      ]
    }
  ]
}
